{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Minuit",
  "version": "0.1.1",
  "identifier": "com.minuit.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Minuit",
        "width": 400,
        "height": 530,
        "resizable": false,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/WeshGuillaume/minuit/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc0MDgzRkJGMUY2NUVGMUUKUldRZTcyVWZ2ejhJZENFYnhqTDZnYlZxYTF0dHVnaHRqREkrTGJadEJoOTFpMGJyVHVtRENhWlkK"
    }
  }
}
